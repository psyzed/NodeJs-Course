<%- include('../includes/head') %>
    <link rel="stylesheet" href="/css/product.css" />
  </head>

  <body>
    <%- include('../includes/nav') %>
    <main>
      <% if(orders.length === 0) { %>
      <h1>No orders yet!</h1>
      <% } else {%>
          <ul>
            <% orders.forEach(order => { %>
              <li>
                <h1># <%= order.id %></h1>
                <ul>
                  <% order.products.forEach(item => { %>
                    <li><%= item.title %> (<%= item.orderItem.quantity %>)</li>
                <%  }); %>
                  </ul>
                </li>
           <% }); %>
          </ul>
        <% } %>
    </main>
    <%- include('../includes/end') %>
